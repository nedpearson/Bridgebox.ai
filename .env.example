# Bridgebox Environment Variables
# Copy this to .env.local and fill in values

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Autumn Billing ────────────────────────────────────────────────────────────
# Get these from https://app.useautumn.com -> Settings -> API Keys
VITE_AUTUMN_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AUTUMN_SECRET_KEY is server-side only — store in Supabase Edge Function secrets, NOT here
# AUTUMN_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

# ── AI Providers (optional) ───────────────────────────────────────────────────
# VITE_AI_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
